# Copy this file to ".env" in the project root and fill in real values.
# This single .env covers both ways of running the app:

# --- Database ---
DB_PASS=change-me-root-password
DB_NAME=canvasclues_db
DB_USER=app
DB_USER_PASSWORD=change-me-user-password
DB_LANG=Europe/Amsterdam

# JDBC URL the backend connects to.
# Running the backend on your host (IntelliJ): use localhost.
# The Docker stack ignores this and sets its own (jdbc:mysql://db:3306/...).
DB_URL=jdbc:mysql://localhost:3306/canvasclues_db

# --- Backend ---
NAME_BACKEND=canvasclues
PORT_BACKEND=8082

# --- Cloudflare Tunnel (optional) ---
# Only needed to expose the app via a Cloudflare tunnel (e.g. on a server).
# Leave blank for local use.
TUNNEL_TOKEN=
